#############################################
# PFE Marketing Agent — authoritative env schema
# Copy to `.env.local` and fill secrets for dev.
# Production values come from your hosting provider / secrets manager.
#############################################

# ── Shared ─────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Backend ────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change_me_to_64_random_bytes
JWT_EXPIRES_IN=24h

# Choose ONE: Atlas (prod) OR local compose mongo
MONGODB_URI=mongodb://mongo:27017/pfe_marketing
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/pfe_marketing?retryWrites=true&w=majority

# ── Internal service URLs (compose network) ────
SCRAPER_URL=http://scraper:8000
N8N_WEBHOOK_URL=http://n8n:5678

# Shared secret between backend and n8n (HMAC header)
N8N_WEBHOOK_SECRET=change_me_random_32_bytes

# ── Pipeline API keys ──────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
VALUESERP_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
APIFY_API_KEY=

# ── Facebook / Meta (scraping) ─────────────────
FB_COOKIE_C_USER=
FB_COOKIE_XS=
FB_APP_ID=
FB_APP_SECRET=
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=

# ── Frontend (build-time — consumed by Vite) ───
VITE_API_URL=/api
VITE_WS_URL=/

# ── Scraper (Python microservice) ──────────────
SCRAPER_USE_BROWSER=false

# ── n8n ────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_ENCRYPTION_KEY=change_me_random_64_bytes
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
