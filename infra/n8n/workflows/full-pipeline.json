    {
      "id": "eval-scrape",
      "name": "Eval Scrape",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1840, 260],
      "parameters": {
        "jsCode": "const cfg = $('Pipeline Inputs').first().json;\nconst j = $input.first().json;\nconst sc = (j && j.data && j.data.statusCount) || {};\nconst total = Number(sc.total || 0);\nconst done = total === 0 ? true : (Number(sc.in_progress || 0) === 0 && Number(sc.pending || 0) === 0);\nconst exhausted = $runIndex >= (Number(cfg.scrapeMaxPolls) || 60);\nreturn [{ json: { ...j, _done: done || exhausted, _scrapeDone: done, _attempt: $runIndex } }];"
      }
    },
