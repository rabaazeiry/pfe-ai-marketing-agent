    {
      "id": "manual-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [-1360, 400],
      "parameters": {}
    },
    {
      "id": "pipeline-inputs",
      "name": "Pipeline Inputs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1160, 400],
      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────────────────────\n// EDIT THESE VALUES, then click \"Test workflow\".\n// ─────────────────────────────────────────────────────────────\nconst CONFIG = {\n  // n8n (Docker) -> backend on the Windows host (npm run dev).\n  // If you ever run the backend in compose instead, use http://backend:5000/api\n  baseUrl: 'http://host.docker.internal:5000/api',\n\n  // Existing app account — the workflow logs in to obtain a JWT.\n  email: 'amirapfa@gmail.com',\n  password: 'CHANGE_ME',\n\n  // Step 1 — project input\n  businessIdea: 'Boutique eco-friendly hotel chain on the Tunisian coast targeting conscious travellers',\n  marketCategory: 'Hotels',\n  targetCountry: 'Tunisie',\n  competitorsHint: [],\n\n  // Steps 4/5 mode:  'fast' = GET existing artifacts | 'full' = regenerate + poll\n  mode: 'fast',\n\n  // Steps 4/5 are industry-scoped (NOT projectId-scoped). Leave '' to\n  // derive from the project's detected industry; or force one of:\n  // hotels | restaurants | beauty | fashion | patisserie\n  industry: '',\n  fallbackIndustry: 'hotels',\n\n  // Step 2\n  discoverMaxResults: 30,\n  swotLimit: 3,                // SWOT is per-competitor (LLM). Cap for demo speed; raise for full coverage.\n\n  // Step 3 scraping\n  scrapePlatform: 'instagram', // 'instagram' = /scrape-instagram | 'both' = /scrape\n  scrapeWaitSeconds: 20,\n  scrapeMaxPolls: 60,          // 60 x 20s = 20 min ceiling\n\n  // Step 4/5 'full' regenerate polling\n  regenWaitSeconds: 30,\n  regenMaxPolls: 60            // 60 x 30s = 30 min ceiling per artifact\n};\nreturn [{ json: CONFIG }];"
      }
    },
    {
      "id": "login",
      "name": "Login",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-960, 400],
      "parameters": {
        "method": "POST",
        "url": "={{ $('Pipeline Inputs').first().json.baseUrl + '/auth/login' }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ email: $('Pipeline Inputs').first().json.email, password: $('Pipeline Inputs').first().json.password }) }}",
        "options": { "timeout": 30000 }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000
    },
    {
      "id": "step1-create-project",
      "name": "Step1 Create Project",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-760, 400],
      "parameters": {
