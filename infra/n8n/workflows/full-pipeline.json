        "jsCode": "const ctx = $('Resolve Context').first().json;\nlet comps = [];\ntry { comps = ($('List Competitors').first().json.data) || []; } catch (e) { comps = []; }\nconst competitorIds = comps.map(c => c._id).filter(Boolean);\nreturn [{ json: { competitorIds, competitorCount: competitorIds.length } }];"
