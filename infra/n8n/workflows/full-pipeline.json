          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ businessIdea: $('Pipeline Inputs').first().json.businessIdea, marketCategory: $('Pipeline Inputs').first().json.marketCategory, targetCountry: $('Pipeline Inputs').first().json.targetCountry, competitorsHint: $('Pipeline Inputs').first().json.competitorsHint }) }}",
        "options": { "timeout": 120000 }
