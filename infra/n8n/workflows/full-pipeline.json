    {
      "id": "swot-targets",
      "name": "SWOT Targets",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [640, 400],
      "parameters": {
        "jsCode": "const cfg = $('Pipeline Inputs').first().json;\nlet comps = [];\ntry { comps = ($('List Competitors').first().json.data) || []; } catch (e) { comps = []; }\nconst limit = Number(cfg.swotLimit) || 0;\nconst picked = comps.slice(0, limit);\nif (picked.length === 0) {\n  // keep the chain alive; the SWOT POST will 400 and is skipped (resilient)\n  return [{ json: { competitorId: '', companyName: '(no competitors / swotLimit=0)' } }];\n}\nreturn picked.map(c => ({ json: { competitorId: c._id, companyName: c.companyName } }));"
      }
    },
