      "typeVersion": 2,
      "position": [3240, 60],
      "parameters": {
        "jsCode": "const cfg = $('Pipeline Inputs').first().json;\nconst j = $input.first().json;\nlet baseline = null;\ntry { baseline = $('Insights Baseline').first().json.data.generated_at || null; } catch (e) { baseline = null; }\nconst cur = (j && j.data && j.data.generated_at) || null;\nconst updated = !!cur && cur !== baseline;\nconst exhausted = $runIndex >= (Number(cfg.regenMaxPolls) || 60);\nreturn [{ json: { ...j, _done: updated || exhausted, _updated: updated, _baseline: baseline, _current: cur, _attempt: $runIndex } }];"
