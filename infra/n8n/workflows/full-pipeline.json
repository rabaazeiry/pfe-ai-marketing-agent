{
  "name": "Full Analysis Pipeline (Steps 1-5)",
  "active": false,
  "settings": { "executionOrder": "v1", "saveManualExecutions": true },
  "pinData": {},
  "meta": {
    "description": "Parallel orchestration layer. Calls the EXISTING backend over HTTP only — no business logic is reimplemented. Manual trigger. Steps 1->2->3 always run; Steps 4/5 branch on the 'mode' input (fast = GET artifacts, full = fire regenerate then poll generated_at). Backend must run on the Windows host (npm run dev); this workflow runs in the n8n container and reaches it via host.docker.internal."
  },
