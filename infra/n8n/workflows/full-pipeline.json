    {
      "id": "resolve-context",
      "name": "Resolve Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-560, 400],
      "parameters": {
        "jsCode": "const cfg = $('Pipeline Inputs').first().json;\nconst login = $('Login').first().json;\nconst step1 = $('Step1 Create Project').first().json;\n\nconst token = login && login.token;\nif (!token) throw new Error('Login returned no token — check email/password/baseUrl');\n\nconst project = (step1 && step1.data && step1.data.project) || {};\nconst projectId = project._id;\nif (!projectId) throw new Error('Step 1 returned no project id');\n\nconst VALID = ['hotels','restaurants','beauty','fashion','patisserie'];\nfunction mapIndustry(raw) {\n  const s = String(raw || '').toLowerCase();\n  if (/hotel|h\\u00f4tel|hospitality|h\\u00f4teller|riad|resort|lodg/.test(s)) return 'hotels';\n  if (/restaur|resto|dining|food|caf[\\u00e9e]|catering/.test(s)) return 'restaurants';\n  if (/beaut|cosmet|spa|salon|skincare|makeup|maquill/.test(s)) return 'beauty';\n  if (/fashion|mode|cloth|apparel|textile|v[\\u00eae]tement/.test(s)) return 'fashion';\n  if (/p[\\u00e2a]tisser|bakery|boulanger|pastry|cake|dessert/.test(s)) return 'patisserie';\n  return null;\n}\nlet industry = String(cfg.industry || '').toLowerCase().trim();\nif (!VALID.includes(industry)) {\n  industry = mapIndustry(project.industry) || mapIndustry(cfg.marketCategory) || cfg.fallbackIndustry || 'hotels';\n}\n\nconst scrapePath = cfg.scrapePlatform === 'both' ? 'scrape' : 'scrape-instagram';\n\nreturn [{ json: {\n  token,\n  projectId,\n  industry,\n  projectIndustryRaw: project.industry || null,\n  mode: (cfg.mode === 'full' ? 'full' : 'fast'),\n  baseUrl: cfg.baseUrl,\n  scrapePath\n} }];"
      }
    },
