# MCP server → existing backend (same HTTP + JWT approach as the n8n layer).
# Copy to .env and adjust. The MCP server logs in with these credentials,
# caches the JWT in memory, and re-logs in automatically on a 401.

# Base URL of the running backend API (no trailing slash).
BACKEND_URL=http://localhost:5000/api

# An existing application account (NOT an admin requirement — any active user).
MCP_BACKEND_EMAIL=n8n-tester@example.com
MCP_BACKEND_PASSWORD=N8nPipeline2026!
